server_host = ${LDAP_URI}
search_base = ou=users,${LDAP_BASE_DN}
version = 3
bind = yes
bind_dn = ${LDAP_BIND_DN}
bind_pw = ${LDAP_BIND_PASSWORD}
# Resolve every alternate address to the entry's single primary mail address.
query_filter = (&(objectClass=mailAliasUser)(mail-alias=%s))
result_attribute = mail
